---
---
<section id="hero">
  <div class="hero-bg"></div>
  <div class="hero-glow"></div>
  <div class="hero-inner">
    <div class="hero-badge">
      <span class="dot"></span>
      <span data-i18n="hero.badge">Musique pour enfants</span>
    </div>
    <div class="hero-logo">
      <svg width="90" height="90" viewBox="0 0 90 90" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- Crescent moon -->
        <path d="M52 10C35 10 22 23 22 42C22 61 35 74 52 74C43 71 38 63 38 42C38 21 43 13 52 10Z" fill="#FFD700" opacity="0.95"/>
        <!-- Large star -->
        <path d="M64 16L66.8 26H77.5L69 32L71.8 42L64 36L56.2 42L59 32L50.5 26H61.2Z" fill="#FFD700"/>
        <!-- Small stars -->
        <circle cx="26" cy="18" r="3.5" fill="#FFD700" opacity="0.7"/>
        <circle cx="72" cy="60" r="2.8" fill="#FFD700" opacity="0.6"/>
        <circle cx="30" cy="65" r="2" fill="#FFD700" opacity="0.5"/>
      </svg>
    </div>
    <h1 class="hero-title">
      Petites <span class="gold">Étoiles</span>
      <span class="arabic">نجوم صغيرة</span>
    </h1>
    <p class="hero-sub" data-i18n="hero.sub">
      Des comptines sur les Prophètes de l'Islam, chantées dans les langues du monde entier — pour que chaque enfant grandisse avec leur histoire dans le cœur.
    </p>
    <div class="hero-ctas">
      <a href="#musique" class="btn-primary" data-i18n="hero.cta1">🎵 Écouter maintenant</a>
      <a href="#boutique" class="btn-secondary" data-i18n="hero.cta2">🛍️ Voir la boutique</a>
    </div>
    <div class="hero-stats">
      <div class="hero-stat">
        <div class="num">4</div>
        <div class="label" data-i18n="hero.stat1">Singles publiés</div>
      </div>
      <div class="hero-stat">
        <div class="num">4</div>
        <div class="label" data-i18n="hero.stat2">Langues</div>
      </div>
      <div class="hero-stat">
        <div class="num">25+</div>
        <div class="label" data-i18n="hero.stat3">Pays</div>
      </div>
      <div class="hero-stat">
        <div class="num">∞</div>
        <div class="label" data-i18n="hero.stat4">Cœurs touchés</div>
      </div>
    </div>
  </div>
  <div class="hero-scroll">
    <div class="scroll-line"></div>
    <span data-i18n="hero.scroll">Découvrir</span>
  </div>
</section>
