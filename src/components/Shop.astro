    <div class="section-header">
      <div class="section-tag" data-i18n="shop.tag">Boutique</div>
      <h2 class="section-title" data-i18n="shop.title">L'univers <em>Petites Étoiles</em></h2>
      <p class="section-desc" data-i18n="shop.desc">Musique, livres illustrés et goodies pour accompagner vos enfants dans la découverte des Prophètes.</p>
    </div>

    <ShopMenu />

    <div class="products-grid">
