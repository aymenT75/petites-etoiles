---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-logo">
          <div class="footer-logo-icon">
            <img src={`${base}/logo-nav.png`} alt="Petites Étoiles" width="50" height="50" />
          </div>
          <span class="footer-logo-text">Petites Étoiles</span>
        </div>
        <p class="footer-tagline" data-i18n="footer.tagline">De la musique qui élève les âmes.</p>
        <div class="footer-socials">
          <a href="https://youtube.com/@petitesetoiles" target="_blank" rel="noopener" class="social-link" aria-label="YouTube">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2C0 8.1 0 12 0 12s0 3.9.5 5.8a3 3 0 0 0 2.1 2.1C4.5 20.4 12 20.4 12 20.4s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1C24 15.9 24 12 24 12s0-3.9-.5-5.8zM9.6 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
          </a>
          <a href="https://instagram.com/petitesetoilesmusic" target="_blank" rel="noopener" class="social-link" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M12 2.2c3.2 0 3.6 0 4.9.1 3.3.1 4.8 1.7 4.9 4.9.1 1.3.1 1.6.1 4.8 0 3.2 0 3.6-.1 4.8-.1 3.2-1.7 4.8-4.9 4.9-1.3.1-1.6.1-4.9.1-3.2 0-3.6 0-4.8-.1-3.3-.1-4.8-1.7-4.9-4.9C2.2 15.6 2.2 15.2 2.2 12c0-3.2 0-3.6.1-4.8C2.4 3.9 4 2.3 7.2 2.3c1.2-.1 1.6-.1 4.8-.1zM12 0C8.7 0 8.3 0 7.1.1 2.7.3.3 2.7.1 7.1.0 8.3 0 8.7 0 12c0 3.3 0 3.7.1 4.9.2 4.4 2.6 6.8 7 7C8.3 24 8.7 24 12 24c3.3 0 3.7 0 4.9-.1 4.4-.2 6.8-2.6 7-7C24 15.7 24 15.3 24 12c0-3.3 0-3.7-.1-4.9-.2-4.4-2.6-6.8-7-7C15.7 0 15.3 0 12 0zm0 5.8a6.2 6.2 0 1 0 0 12.4A6.2 6.2 0 0 0 12 5.8zm0 10.2a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.4-11.8a1.4 1.4 0 1 0 0 2.8 1.4 1.4 0 0 0 0-2.8z"/></svg>
          </a>
          <a href="https://tiktok.com/@petitesetoilesmusic" target="_blank" rel="noopener" class="social-link" aria-label="TikTok">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M19.6 3.3A4.5 4.5 0 0 1 15.2 0h-3.3v16.4a2.7 2.7 0 0 1-2.7 2.3 2.7 2.7 0 0 1-2.7-2.7 2.7 2.7 0 0 1 2.7-2.7c.3 0 .5 0 .7.1V10a6 6 0 0 0-.7 0 6 6 0 0 0-6 6 6 6 0 0 0 6 6 6 6 0 0 0 6-6V8.2a7.8 7.8 0 0 0 4.6 1.5V6.4a4.5 4.5 0 0 1-2.9-3.1z"/></svg>
          </a>
          <a href="https://facebook.com/petitesetoilesmusic" target="_blank" rel="noopener" class="social-link" aria-label="Facebook">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M24 12.1C24 5.4 18.6 0 12 0S0 5.4 0 12.1C0 18.1 4.4 23 10.1 24v-8.4H7.1v-3.5h3V9.4c0-3 1.8-4.6 4.5-4.6 1.3 0 2.7.2 2.7.2v2.9h-1.5c-1.5 0-1.9.9-1.9 1.9v2.2h3.3l-.5 3.5h-2.8V24C19.6 23 24 18.1 24 12.1z"/></svg>
          </a>
        </div>
      </div>

      <div class="footer-nav">
        <div class="footer-nav-group">
          <div class="footer-nav-title" data-i18n="footer.music">Musique</div>
          <a href="#musique" data-i18n="footer.singles">Les singles</a>
          <a href="#boutique" data-i18n="footer.shop">Boutique</a>
          <a href="https://open.spotify.com/artist/petitesetoiles" target="_blank" rel="noopener">Spotify</a>
          <a href="https://music.apple.com/artist/petitesetoiles" target="_blank" rel="noopener">Apple Music</a>
        </div>
        <div class="footer-nav-group">
          <div class="footer-nav-title" data-i18n="footer.info">Informations</div>
          <a href="#apropos" data-i18n="footer.about">À propos</a>
          <a href="#contact" data-i18n="footer.contact">Contact</a>
          <a href="#" data-i18n="footer.press">Presse</a>
        </div>
        <div class="footer-nav-group">
          <div class="footer-nav-title" data-i18n="footer.legal">Légal</div>
          <a href="#" data-i18n="footer.privacy">Confidentialité</a>
          <a href="#" data-i18n="footer.terms">CGU</a>
          <a href="#" data-i18n="footer.cookies">Cookies</a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">© 2026 Petites Étoiles — <span data-i18n="footer.copy">Tous droits réservés</span></p>
      <p class="footer-love" data-i18n="footer.love">Fait avec ❤️ pour les enfants du monde entier</p>
    </div>
  </div>
</footer>
