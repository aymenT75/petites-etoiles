---
<section id="musique">
  <div class="container">
    <div class="section-header">
      <div class="section-tag" data-i18n="music.tag">Nos singles</div>
      <h2 class="section-title" data-i18n="music.title">La saga du <em>Prophète Adam</em></h2>
      <p class="section-desc" data-i18n="music.desc">Le premier single de Petites Étoiles raconte l'histoire d'Adam ﷺ en 6 langues — pour atteindre chaque enfant, partout dans le monde.</p>
    </div>
    <div class="singles-grid">
      {singles.map((s) => (
        <div class={`single-card reveal ${s.delay}`}>
          <div class="single-cover">
            <img src={s.cover} alt={s.alt} loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
            <div class="single-cover-fallback"><span>✦</span></div>
            <span class="single-cover-lang">{s.lang}</span>
            <a href={s.spotify} target="_blank" class="play-btn" title={s.playTitle}>▶</a>
          </div>
          <div class="single-info">
            <div class="single-title-ar" style={s.latinStyle}>{s.titleAr}</div>
            <div class="single-title-latin">{s.titleLatin}</div>
            <div class="single-streaming">
              <a href={s.spotify} target="_blank" class="stream-link spotify">🎵 Spotify</a>
              <a href={s.apple}   target="_blank" class="stream-link apple">🎵 Apple</a>
              <a href={s.youtube} target="_blank" class="stream-link youtube">▶ YouTube</a>
              <a href={s.deezer}  target="_blank" class="stream-link deezer">🎵 Deezer</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
