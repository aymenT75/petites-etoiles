---
import Layout from '../layouts/Layout.astro';
import Starfield from '../components/Starfield.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Cart from '../components/Cart.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Pyjamas — Petites Étoiles">
  <Starfield />
  <Nav home={false} />

  <section id="pyjamas-page" style="padding-top:7rem">
    <div class="container">
      <a href={`${base}/`} class="back-link" style="display:inline-flex;align-items:center;gap:0.4rem;color:var(--text-muted);font-size:0.875rem;margin-bottom:1.5rem;">← Retour à l'accueil</a>
      <div class="section-header">
        <div class="section-tag">Boutique</div>
        <h1 class="section-title">Les <em>pyjamas</em> Petites Étoiles</h1>
        <p class="section-desc">Des pyjamas enfant illustrés à l'effigie des Prophètes, pour de belles nuits étoilées.</p>
      </div>

      <div class="products-grid">
        <!-- Pyjama Mohamed ﷺ — Enfant -->
        <div class="product-card reveal">
          <span class="product-badge new">Nouveau</span>
          <div class="product-image product-image--photo">
            <div class="product-image-bg" style="background:linear-gradient(135deg,#0f1c33,#1a2f4d)"></div>
            <img src={`${base}/pyjama-mohammed.jpg`} alt="Pyjama Mohamed ﷺ — Enfant" class="product-photo" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
            <div class="product-image-fallback" style="display:none"><span>🛌</span></div>
          </div>
          <div class="product-body">
            <div class="product-name">Pyjama Mohamed ﷺ — Enfant</div>
            <div class="product-desc">Pyjama bleu marine — un chameau sous la lune et les étoiles.</div>
            <div class="product-footer">
              <div class="product-price" style="font-size:0.95rem;color:var(--text-muted);font-weight:600">Prix à venir</div>
            </div>
          </div>
        </div>
        <!-- Pyjama Adam ﷺ — Enfant -->
        <div class="product-card reveal reveal-delay-1">
          <span class="product-badge new">Nouveau</span>
          <div class="product-image product-image--photo">
            <div class="product-image-bg" style="background:linear-gradient(135deg,#c8ead9,#e4f5ec)"></div>
            <img src={`${base}/pyjama-adam.jpg`} alt="Pyjama Adam ﷺ — Enfant" class="product-photo" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
            <div class="product-image-fallback" style="display:none"><span>🛌</span></div>
          </div>
          <div class="product-body">
            <div class="product-name">Pyjama Adam ﷺ — Enfant</div>
            <div class="product-desc">Pyjama vert menthe — le lion, l'agneau et le perroquet du jardin d'Éden.</div>
            <div class="product-footer">
              <div class="product-price" style="font-size:0.95rem;color:var(--text-muted);font-weight:600">Prix à venir</div>
            </div>
          </div>
        </div>
        <!-- Pyjama Souleymane ﷺ — Enfant -->
        <div class="product-card reveal reveal-delay-2">
          <span class="product-badge new">Nouveau</span>
          <div class="product-image product-image--photo">
            <div class="product-image-bg" style="background:linear-gradient(135deg,#0f1c33,#1a2f4d)"></div>
            <img src={`${base}/pyjama-souleymane.jpg`} alt="Pyjama Souleymane ﷺ — Enfant" class="product-photo" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
            <div class="product-image-fallback" style="display:none"><span>🛌</span></div>
          </div>
          <div class="product-body">
            <div class="product-name">Pyjama Souleymane ﷺ — Enfant</div>
            <div class="product-desc">Pyjama bleu marine — le château, le cheval ailé et la huppe.</div>
            <div class="product-footer">
              <div class="product-price" style="font-size:0.95rem;color:var(--text-muted);font-weight:600">Prix à venir</div>
            </div>
          </div>
        </div>
        <!-- Pyjama Nouh ﷺ — Enfant -->
        <div class="product-card reveal reveal-delay-3">
          <span class="product-badge new">Nouveau</span>
          <div class="product-image product-image--photo">
            <div class="product-image-bg" style="background:linear-gradient(135deg,#cfe8f5,#e8f4fb)"></div>
            <img src={`${base}/pyjama-nouh.jpg`} alt="Pyjama Nouh ﷺ — Enfant" class="product-photo" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
            <div class="product-image-fallback" style="display:none"><span>🛌</span></div>
          </div>
          <div class="product-body">
            <div class="product-name">Pyjama Nouh ﷺ — Enfant</div>
            <div class="product-desc">Pyjama bleu ciel — l'Arche de Noé et l'arc-en-ciel.</div>
            <div class="product-footer">
              <div class="product-price" style="font-size:0.95rem;color:var(--text-muted);font-weight:600">Prix à venir</div>
            </div>
          </div>
        </div>
        <!-- Pyjama Moussa ﷺ — Enfant -->
        <div class="product-card reveal">
          <span class="product-badge new">Nouveau</span>
          <div class="product-image product-image--photo">
            <div class="product-image-bg" style="background:linear-gradient(135deg,#f4f4f4,#ffffff)"></div>
            <img src={`${base}/pyjama-moussa.jpg`} alt="Pyjama Moussa ﷺ — Enfant" class="product-photo" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
            <div class="product-image-fallback" style="display:none"><span>🛌</span></div>
          </div>
          <div class="product-body">
            <div class="product-name">Pyjama Moussa ﷺ — Enfant</div>
            <div class="product-desc">Pyjama blanc — le trident, le soleil et les dauphins.</div>
            <div class="product-footer">
              <div class="product-price" style="font-size:0.95rem;color:var(--text-muted);font-weight:600">Prix à venir</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Footer home={false} />
  <Cart />

  <script is:inline src="/petites-etoiles/scripts/main.js"></script>
</Layout>
