          </div>
        </div>

        <!-- T-shirt Adam -->
        <div class="product-card reveal reveal-delay-2" data-product='{"id":9,"name":"T-shirt Adam ﷺ — Enfant","price":24.99,"icon":"👕"}'>
          <span class="product-badge new">Nouveau</span>
          <div class="product-image product-image--photo">
            <div class="product-image-bg" style="background:linear-gradient(135deg,#c8ead9,#e4f5ec)"></div>
