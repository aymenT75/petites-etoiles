---
import Layout from '../layouts/Layout.astro';
import Starfield from '../components/Starfield.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Cart from '../components/Cart.astro';
import ShopMenu from '../components/ShopMenu.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="T-shirts — Petites Étoiles">
  <Starfield />
  <Nav home={false} />

  <section id="tshirts-page" style="padding-top:7rem">
    <div class="container">
      <a href={`${base}/`} class="back-link" style="display:inline-flex;align-items:center;gap:0.4rem;color:var(--text-muted);font-size:0.875rem;margin-bottom:1.5rem;">← Retour à l'accueil</a>
      <div class="section-header">
        <div class="section-tag">Boutique</div>
        <h1 class="section-title">Les <em>t-shirts</em> Petites Étoiles</h1>
        <p class="section-desc">Des t-shirts enfant 100% coton bio, illustrés avec les histoires des Prophètes. D'autres produits (livres, posters, gourdes...) arrivent bientôt.</p>
      </div>

      <ShopMenu active="t-shirts" />

      <div class="products-grid">
        <!-- T-shirt Mohammed -->
        <div class="product-card reveal" data-product='{"id":3,"name":"T-shirt Mohamed ﷺ — Enfant","price":24.99,"icon":"👕"}'>
          <span class="product-badge new">Nouveau</span>
          <div class="product-image product-image--photo">
            <div class="product-image-bg" style="background:linear-gradient(135deg,#0f1c33,#1a2f4d)"></div>
            <img src={`${base}/tshirt-mohammed.jpg`} alt="T-shirt Mohamed ﷺ" class="product-photo" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
            <div class="product-image-fallback" style="display:none"><span>👕</span></div>
          </div>
          <div class="product-body">
            <div class="product-name">T-shirt Mohamed ﷺ — Enfant</div>
            <div class="product-desc">T-shirt bleu marine — la grotte de la révélation, un jeune chameau et sa toile d'araignée protectrice. 100% coton bio.</div>
            <div class="size-chips">
              <button class="size-chip" type="button" onclick="this.parentElement.querySelectorAll('.size-chip').forEach(b => b.classList.remove('active')); this.classList.add('active')">2 ans</button>
              <button class="size-chip" type="button" onclick="this.parentElement.querySelectorAll('.size-chip').forEach(b => b.classList.remove('active')); this.classList.add('active')">4 ans</button>
              <button class="size-chip" type="button" onclick="this.parentElement.querySelectorAll('.size-chip').forEach(b => b.classList.remove('active')); this.classList.add('active')">6 ans</button>
              <button class="size-chip" type="button" onclick="this.parentElement.querySelectorAll('.size-chip').forEach(b => b.classList.remove('active')); this.classList.add('active')">8 ans</button>
              <button class="size-chip" type="button" onclick="this.parentElement.querySelectorAll('.size-chip').forEach(b => b.classList.remove('active')); this.classList.add('active')">10 ans</button>
              <button class="size-chip" type="button" onclick="this.parentElement.querySelectorAll('.size-chip').forEach(b => b.classList.remove('active')); this.classList.add('active')">12 ans</button>
              <button class="size-chip" type="button" onclick="this.parentElement.querySelectorAll('.size-chip').forEach(b => b.classList.remove('active')); this.classList.add('active')">14 ans</button>
            </div>
            <div class="product-footer">
              <div class="product-price" style="font-size:0.95rem;color:var(--text-muted);font-weight:600">Prix à venir</div>
            </div>
          </div>
        </div>

        <!-- T-shirt Souleymane -->
        <div class="product-card reveal reveal-delay-1" data-product='{"id":7,"name":"T-shirt Souleymane ﷺ — Enfant","price":24.99,"icon":"👕"}'>
          <span class="product-badge new">Nouveau</span>
          <div class="product-image product-image--photo">
