---
import Layout from '../layouts/Layout.astro';
import Starfield from '../components/Starfield.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Cart from '../components/Cart.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Coffrets cadeaux — Petites Étoiles">
  <Starfield />
  <Nav home={false} />

  <section id="coffrets-page" style="padding-top:7rem">
    <div class="container">
      <a href={`${base}/`} class="back-link" style="display:inline-flex;align-items:center;gap:0.4rem;color:var(--text-muted);font-size:0.875rem;margin-bottom:1.5rem;">← Retour à l'accueil</a>
      <div class="section-header">
        <div class="section-tag">Boutique</div>
        <h1 class="section-title">Les <em>coffrets cadeaux</em> Petites Étoiles</h1>
        <p class="section-desc">Des coffrets cadeaux tout-en-un : un t-shirt assorti à des jouets, pour offrir l'univers Petites Étoiles aux petits.</p>
      </div>

      <div class="products-grid">
        <!-- Coffret cadeau Moussa ﷺ — Bébé -->
        <div class="product-card reveal">
          <span class="product-badge new">Nouveau</span>
          <div class="product-image product-image--photo">
            <div class="product-image-bg" style="background:linear-gradient(135deg,#cfe8f5,#e8f4fb)"></div>
            <img src={`${base}/coffret-moussa.jpg`} alt="Coffret cadeau Moussa ﷺ — Bébé" class="product-photo" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
            <div class="product-image-fallback" style="display:none"><span>🎁</span></div>
          </div>
          <div class="product-body">
            <div class="product-name">Coffret cadeau Moussa ﷺ — Bébé</div>
            <div class="product-desc">T-shirt Moussa et jouets d'éveil assortis (hochets, anneaux de dentition), dans un coffret prêt à offrir.</div>
            <div class="product-footer">
              <div class="product-price" style="font-size:0.95rem;color:var(--text-muted);font-weight:600">Prix à venir</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Footer home={false} />
  <Cart />

  <script is:inline src="/petites-etoiles/scripts/main.js"></script>
</Layout>
