---
import Layout from '../layouts/Layout.astro';
import Starfield from '../components/Starfield.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Cart from '../components/Cart.astro';
import ShopMenu from '../components/ShopMenu.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Gourdes — Petites Étoiles">
  <Starfield />
  <Nav home={false} />

  <section id="gourdes-page" style="padding-top:7rem">
    <div class="container">
      <a href={`${base}/`} class="back-link" style="display:inline-flex;align-items:center;gap:0.4rem;color:var(--text-muted);font-size:0.875rem;margin-bottom:1.5rem;">← Retour à l'accueil</a>
      <div class="section-header">
        <div class="section-tag">Boutique</div>
        <h1 class="section-title">Les <em>gourdes</em> Petites Étoiles</h1>
        <p class="section-desc">Des gourdes en inox pour enfant, illustrées avec les histoires des Prophètes. 100% inox alimentaire.</p>
      </div>

      <ShopMenu active="gourdes" />

      <div class="products-grid">
        <!-- Gourde Mohamed ﷺ — Enfant -->
        <div class="product-card reveal">
          <span class="product-badge new">Nouveau</span>
          <div class="product-image product-image--photo">
            <div class="product-image-bg" style="background:linear-gradient(135deg,#0f1c33,#1a2f4d)"></div>
            <img src={`${base}/gourde-mohammed.jpg`} alt="Gourde Mohamed ﷺ — Enfant" class="product-photo" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
            <div class="product-image-fallback" style="display:none"><span>🥤</span></div>
          </div>
          <div class="product-body">
            <div class="product-name">Gourde Mohamed ﷺ — Enfant</div>
            <div class="product-desc">Gourde inox blanche — un jeune chameau dans le désert étoilé.</div>
            <div class="product-footer">
              <div class="product-price" style="font-size:0.95rem;color:var(--text-muted);font-weight:600">Prix à venir</div>
            </div>
          </div>
        </div>
        <!-- Gourde Adam ﷺ — Enfant -->
        <div class="product-card reveal reveal-delay-1">
          <span class="product-badge new">Nouveau</span>
          <div class="product-image product-image--photo">
            <div class="product-image-bg" style="background:linear-gradient(135deg,#c8ead9,#e4f5ec)"></div>
            <img src={`${base}/gourde-adam.jpg`} alt="Gourde Adam ﷺ — Enfant" class="product-photo" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
            <div class="product-image-fallback" style="display:none"><span>🥤</span></div>
          </div>
          <div class="product-body">
            <div class="product-name">Gourde Adam ﷺ — Enfant</div>
            <div class="product-desc">Gourde inox verte — fleurs, papillons et fraises du jardin d'Éden.</div>
            <div class="product-footer">
              <div class="product-price" style="font-size:0.95rem;color:var(--text-muted);font-weight:600">Prix à venir</div>
            </div>
          </div>
        </div>
        <!-- Gourde Souleymane ﷺ — Enfant -->
        <div class="product-card reveal reveal-delay-2">
          <span class="product-badge new">Nouveau</span>
          <div class="product-image product-image--photo">
            <div class="product-image-bg" style="background:linear-gradient(135deg,#e8f0f8,#d0e4f5)"></div>
            <img src={`${base}/gourde-souleymane.jpg`} alt="Gourde Souleymane ﷺ — Enfant" class="product-photo" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
            <div class="product-image-fallback" style="display:none"><span>🥤</span></div>
          </div>
          <div class="product-body">
            <div class="product-name">Gourde Souleymane ﷺ — Enfant</div>
            <div class="product-desc">Gourde inox — licorne ailée, abeille et Bismillah dans les nuages.</div>
            <div class="product-footer">
              <div class="product-price" style="font-size:0.95rem;color:var(--text-muted);font-weight:600">Prix à venir</div>
            </div>
          </div>
        </div>
        <!-- Gourde Moussa ﷺ — Enfant -->
        <div class="product-card reveal reveal-delay-3">
          <span class="product-badge new">Nouveau</span>
          <div class="product-image product-image--photo">
            <div class="product-image-bg" style="background:linear-gradient(135deg,#cfe8f5,#e8f4fb)"></div>
            <img src={`${base}/gourde-moussa.jpg`} alt="Gourde Moussa ﷺ — Enfant" class="product-photo" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
            <div class="product-image-fallback" style="display:none"><span>🥤</span></div>
          </div>
          <div class="product-body">
            <div class="product-name">Gourde Moussa ﷺ — Enfant</div>
            <div class="product-desc">Gourde inox — les vagues de la mer et ses créatures marines.</div>
            <div class="product-footer">
              <div class="product-price" style="font-size:0.95rem;color:var(--text-muted);font-weight:600">Prix à venir</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Footer home={false} />
  <Cart />

  <script is:inline src="/petites-etoiles/scripts/main.js"></script>
</Layout>
