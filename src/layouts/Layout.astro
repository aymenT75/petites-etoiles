---
import '../styles/global.css';
interface Props { title?: string; }
const { title = 'Petites Étoiles | نجوم صغيرة — Musique pour enfants' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="fr" data-lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content="Petites Étoiles — Des comptines inspirantes pour les enfants du monde entier. Singles disponibles en arabe, anglais, ourdou et indonésien." />
  <meta property="og:title" content="Petites Étoiles | نجوم صغيرة" />
  <meta property="og:description" content="Des comptines inspirantes pour les enfants du monde entier." />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={`${base}/logo-512.png`} />
  <meta name="theme-color" content="#0d0520" />
  <link rel="icon" type="image/png" sizes="64x64" href={`${base}/favicon-64.png`} />
  <link rel="icon" type="image/png" sizes="32x32" href={`${base}/favicon-32.png`} />
  <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Cairo:wght@400;600;700;800;900&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet" />
</head>
<body>
  <slot />
</body>
</html>
